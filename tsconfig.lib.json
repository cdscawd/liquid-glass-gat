{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/index.ts",
    "src/components/**/*",
    "src/lib/liquid-glass/**/*",
    "src/styles/**/*"
  ],
  "exclude": [
    "src/preview",
    "src/pages",
    "src/engine",
    "src/hooks",
    "src/App.tsx",
    "src/main.tsx"
  ]
}
