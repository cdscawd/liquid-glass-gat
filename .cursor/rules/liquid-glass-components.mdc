## 3. 核心效果管线（不可修改）

所有玻璃宿主 **必须** 走 `useLiquidGlassEffect`，禁止手写 `useId` + ResizeObserver + `generateDisplacementMap`。

```tsx
import {
  GLASS_SHAPE,
  LiquidGlassFilter,
  useLiquidGlassEffect,
  type LiquidGlassParams,
} from '../../lib/liquid-glass'

export function LiquidGlassXxx({ glassParams, className = '', style, ...props }: LiquidGlassXxxProps) {
  const { hostRef, filterId, mapId, mapUrl, filterSize, filterStyle, borderRadius } =
    useLiquidGlassEffect<HTMLDivElement>(glassParams, {
      preset: { borderRadius: GLASS_SHAPE.default }, // 按形状选 preset
    })

  return (
    <>
      <LiquidGlassFilter
        filterId={filterId}
        mapId={mapId}
        mapUrl={mapUrl}
        width={filterSize.width}
        height={filterSize.height}
      />
      <div
        ref={hostRef}
        className={`liquid-glass-xxx${className ? ` ${className}` : ''}`}
        style={{ ...filterStyle, borderRadius, ...style }}
        {...props}
      />
    </>
  )
}
```

**固定项（全库一致，改一处需全库同步）**

- `BACKDROP_FILTER` — `blur(0.25px) contrast(1.2) brightness(1.05) saturate(1.1)`
- `DISPLACEMENT_SCALE` — feDisplacementMap scale
- `generateDisplacementMap` — SDF 边缘折射算法

**禁止**

- 用 CSS `filter: blur()` 冒充 liquid glass
- 修改 `feDisplacementMap` channel / scale 而不更新全库
- 在组件内复制 Filter 或贴图生成逻辑

